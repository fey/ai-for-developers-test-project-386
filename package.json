{
  "name": "ai-assisted-development-calendar-slot-project",
  "version": "1.0.0",
  "description": "Calendar slot booking service",
  "type": "module",
  "scripts": {
    "build": "npm run build:server && npm run build:frontend",
    "build:server": "tsc -p tsconfig.json",
    "build:frontend": "vite build",
    "dev": "concurrently -k -n backend,frontend -c yellow,cyan \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:prism": "npm run tsp:compile && prism mock tsp-output/@typespec/openapi3/openapi.yaml --host 0.0.0.0 --port 8080",
    "dev:backend": "tsx watch src/dev.ts",
    "dev:frontend": "vite",
    "dev:server": "tsx watch src/dev.ts",
    "dev:web": "vite",
    "demo:screenshots": "tsx demo_utils/screenshots.ts",
    "demo:video": "tsx demo_utils/screencast.ts",
    "demo": "npm run demo:screenshots && npm run demo:video",
    "start": "node dist/dev.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "lint": "biome lint .",
    "tsp:compile": "tsp compile src/main.tsp",
    "tsp:watch": "tsp compile src/main.tsp --watch"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/static": "^9.0.0",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.4",
    "fastify-cli": "^8.0.0",
    "i18next": "^26.0.2",
    "i18next-http-backend": "^3.0.2",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.1",
    "react-router-dom": "^7.13.2",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@playwright/test": "^1.58.2",
    "@stoplight/prism-cli": "^5.14.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typespec/compiler": "^1.10.0",
    "@typespec/openapi3": "^1.10.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
